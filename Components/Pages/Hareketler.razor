@page "/hareketler"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService Auth
@inject AppDbContext Db
@using Microsoft.EntityFrameworkCore
@using MuhasebeApp.Web.Data

<PageTitle>Hareketler</PageTitle>

<h1 class="mb-3"><i class="bi bi-list-ul"></i> Hareketler</h1>

<input @bind="_arama" @bind:event="oninput" @bind:after="Yukle" class="form-control mb-3" placeholder="Profil veya açıklama..."/>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Tarih</th>
                <th>Profil</th>
                <th>Açıklama</th>
                <th>Tip</th>
                <th class="text-end">Tutar</th>
            </tr>
        </thead>
        <tbody>
            @if (_liste.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Hareket yok.</td></tr>
            }
            @foreach (var h in _liste)
            {
                <tr>
                    <td>@h.Tarih.ToString("dd.MM.yyyy")</td>
                    <td>@h.Cari?.Unvan</td>
                    <td>@h.Aciklama</td>
                    <td><span class="badge @(h.Tip == HareketTipi.Alacak ? "bg-success" : "bg-danger")">@h.TipMetni</span></td>
                    <td class="text-end fw-bold">@h.Tutar.ToString("N2") ₺</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private string? _userId;
    private string _arama = "";
    private List<Hareket> _liste = new();

    protected override async Task OnInitializedAsync()
    {
        _userId = await Auth.GetUserIdAsync();
        await Yukle();
    }

    private async Task Yukle()
    {
        if (string.IsNullOrEmpty(_userId)) return;
        var q = Db.Hareketler.Include(h => h.Cari).Where(h => h.UserId == _userId);
        if (!string.IsNullOrWhiteSpace(_arama))
        {
            var a = "%" + _arama + "%";
            q = q.Where(h => EF.Functions.Like(h.Aciklama ?? "", a) || EF.Functions.Like(h.Cari!.Unvan, a));
        }
        _liste = await q.OrderByDescending(h => h.Tarih).Take(200).ToListAsync();
    }
}
