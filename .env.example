# Production / Dokploy ortam değişkenleri örneği
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.

# PostgreSQL bağlantısı — URI veya klasik format desteklenir
ConnectionStrings__DefaultConnection=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
